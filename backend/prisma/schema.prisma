// prisma/schema.prisma
// =============================================
// BINUS Marketplace - Database Schema
// =============================================

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  studentId  String?  @unique
  phone      String?
  bio        String?  @db.Text
  avatarUrl  String?
  role       Role     @default(STUDENT)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  // Virtual balance: saldo simulasi untuk sistem escrow
  // Buyer topup saldo → beli → saldo masuk escrow → COMPLETED → seller terima
  balance    Decimal  @default(0.00) @db.Decimal(12, 2)
  escrow     Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listings           Listing[]
  buyerTransactions  Transaction[] @relation("BuyerTransactions")
  sellerTransactions Transaction[] @relation("SellerTransactions")
  reviewsGiven       Review[]      @relation("ReviewsGiven")
  reviewsReceived    Review[]      @relation("ReviewsReceived")
  complaints         Complaint[]
  messagesSent       Message[]     @relation("MessagesSent")
  chatRoomsA         ChatRoom[]    @relation("UserA")
  chatRoomsB         ChatRoom[]    @relation("UserB")

  @@map("users")
}

enum Role {
  STUDENT
  ADMIN
}

// ─────────────────────────────────────────────
// LISTING (Product / Service)
// ─────────────────────────────────────────────
model Listing {
  id          String        @id @default(uuid())
  title       String
  description String        @db.Text
  price       Decimal       @db.Decimal(12, 2)
  category    Category
  type        ListingType   @default(PRODUCT)
  images      String        @default("[]") @db.Text
  status      ListingStatus @default(PENDING)
  condition   Condition?
  // Stock management — hanya berlaku untuk tipe PRODUCT
  // Jika null = tidak dibatasi (untuk SERVICE)
  stock       Int?          // Stok awal yang diset seller
  stockLeft   Int?          // Stok tersisa (berkurang tiap transaksi PAID)
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  transactions Transaction[]

  @@map("listings")
}

enum Category {
  ELECTRONICS
  BOOKS
  FASHION
  FOOD
  SERVICES
  SPORTS
  OTHER
}

enum ListingType {
  PRODUCT
  SERVICE
}

// Komentar inline pada nilai enum tidak didukung Prisma,
// jadi ditulis di atas sebagai block comment.
// PENDING  = Menunggu moderasi admin
// ACTIVE   = Disetujui, tampil di marketplace
// REJECTED = Ditolak admin
// SOLD     = Terjual (khusus PRODUCT)
// INACTIVE = Dinonaktifkan oleh pemilik
enum ListingStatus {
  PENDING
  ACTIVE
  REJECTED
  SOLD
  INACTIVE
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

// ─────────────────────────────────────────────
// TRANSACTION
// ─────────────────────────────────────────────
// PENDING   = Menunggu pembayaran dari buyer
// PAID      = Buyer sudah bayar, masuk escrow, menunggu konfirmasi seller
// CONFIRMED = Seller konfirmasi, barang sedang diproses
// COMPLETED = Selesai, dana dilepas ke seller
// CANCELLED = Dibatalkan, dana dikembalikan ke buyer
model Transaction {
  id             String            @id @default(uuid())
  listingId      String
  listing        Listing           @relation(fields: [listingId], references: [id])
  buyerId        String
  buyer          User              @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId       String
  seller         User              @relation("SellerTransactions", fields: [sellerId], references: [id])
  status         TransactionStatus @default(PENDING)
  note           String?
  quantity       Int               @default(1)  // Jumlah yang dibeli buyer
  price          Decimal           @db.Decimal(12, 2) // Harga satuan
  totalPrice     Decimal           @db.Decimal(12, 2) // Harga total (price x quantity)
  commissionRate Decimal           @default(5.00) @db.Decimal(5, 2)
  commissionAmt  Decimal           @default(0.00) @db.Decimal(12, 2)
  sellerReceives Decimal           @default(0.00) @db.Decimal(12, 2)
  isEscrowHeld   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  review Review?

  @@map("transactions")
}

enum TransactionStatus {
  PENDING    // Menunggu pembayaran buyer
  PAID       // Buyer sudah bayar, dana di escrow
  CONFIRMED  // Seller konfirmasi
  COMPLETED  // Selesai, dana dilepas ke seller
  CANCELLED  // Dibatalkan
}

// ─────────────────────────────────────────────
// COMMISSION SETTING (Admin bisa ubah %)
// ─────────────────────────────────────────────
model CommissionSetting {
  id        String   @id @default(uuid())
  rate      Decimal  @db.Decimal(5, 2) // contoh: 5.00 = 5%
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_settings")
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────
model Review {
  id            String      @id @default(uuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  reviewerId    String
  reviewer      User        @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId    String
  reviewee      User        @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())

  @@map("reviews")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────
// FIX: @@unique([userAId, userBId]) saja TIDAK CUKUP karena
// jika A=1,B=2 sudah ada, maka A=2,B=1 masih bisa dibuat
// dan akan jadi duplikat room untuk pasangan yang sama.
// Solusinya: enforce urutan di aplikasi (userAId < userBId)
// sehingga pasangan apapun selalu disimpan dengan ID terkecil di userA.
// Logika ini diterapkan di chat.controller.js saat getOrCreateChatRoom.
model ChatRoom {
  id        String    @id @default(uuid())
  userAId   String
  userA     User      @relation("UserA", fields: [userAId], references: [id])
  userBId   String
  userB     User      @relation("UserB", fields: [userBId], references: [id])
  createdAt DateTime  @default(now())

  messages Message[]

  @@unique([userAId, userBId])
  @@map("chat_rooms")
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])
  content    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────────
// COMPLAINT
// ─────────────────────────────────────────────
// OPEN      = Baru dibuat, belum ditangani
// IN_REVIEW = Sedang ditinjau admin
// RESOLVED  = Selesai ditangani
// DISMISSED = Ditolak / tidak valid
model Complaint {
  id          String          @id @default(uuid())
  reporterId  String
  reporter    User            @relation(fields: [reporterId], references: [id])
  targetType  ComplaintTarget
  targetId    String
  reason      String  @db.Text
  description String? @db.Text
  status      ComplaintStatus @default(OPEN)
  adminNote   String? @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("complaints")
}

enum ComplaintTarget {
  USER
  LISTING
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}
