# =============================================
# BINUS Marketplace - Environment Variables
# =============================================
# CARA PAKAI:
# 1. Copy file ini: cp .env.example .env
# 2. Isi nilai yang bertanda <GANTI_INI>
# 3. Jangan pernah commit file .env ke Git!
# =============================================

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL via XAMPP) ────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/NAMA_DATABASE
# Username XAMPP default : root
# Password XAMPP default : (kosong)
DATABASE_URL="mysql://root:@localhost:3306/binus_marketplace"

# ── JWT ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<GANTI_DENGAN_STRING_ACAK_PANJANG>"
JWT_EXPIRES_IN="7d"

# ── Mock SSO BINUS ────────────────────────────
SSO_ALLOWED_DOMAINS="@binus.ac.id,@student.binus.ac.id,@binus.edu"

# ── File Upload ───────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR="uploads"

# ── CORS ──────────────────────────────────────
CORS_ORIGIN="*"
